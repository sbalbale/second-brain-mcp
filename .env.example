# --- Required ---

# Absolute path to the Obsidian vault this server exposes.
# On Linux/macOS this is a normal path; on Windows use forward slashes.
VAULT_ROOT=/vault

# --- Transport ---

# "http" for streamable HTTP (remote/Cloudflare Tunnel), "stdio" for local.
TRANSPORT=http

# Port the HTTP server listens on. Only reachable on localhost by default.
PORT=8787

# Bind address. Keep 127.0.0.1 when fronted by cloudflared (outbound tunnel
# connects to localhost). Use 0.0.0.0 only inside containers.
HOST=127.0.0.1

# --- Auth ---

# Static bearer token checked on every MCP request (Authorization: Bearer <token>).
# Generate with: openssl rand -hex 32
# This is the MINIMUM auth. Cloudflare Access in front is strongly recommended.
AUTH_TOKEN=

# Cloudflare Access JWT verification. When set, requests must carry a valid
# Cf-Access-Jwt-Assertion header and the JWT aud must match CF_ACCESS_AUD.
# Leave blank to disable (not recommended for remote deployments).
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# --- Behavior ---

# Whether write/ingest tools auto-commit the vault's git repo. Requires the
# vault to be an initialized git repo. Set to "false" to opt out.
VAULT_AUTOCOMMIT=true

# Default response format for tools that support it: markdown | json.
DEFAULT_RESPONSE_FORMAT=markdown

# Optional: OpenAI API Key for Semantic Search (RAG)
OPENAI_API_KEY=
